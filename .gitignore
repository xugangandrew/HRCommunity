static/uploads/*.docx
static/uploads/*.ppt
static/uploads/*.pptx
static/uploads/*.zip
static/uploads/*.rar
!static/uploads/.gitkeep

# 环境与日志
.env
*.log
nohup.out

# 编辑器
.vscode/
.idea/
*.swp
*.swo

